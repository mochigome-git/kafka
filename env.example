# ---- EC2 #1 (.env) ----
NODE_ID=1
ADVERTISED_HOST=kafka1.general-my.com
# Generate ONCE with: docker run --rm confluentinc/cp-kafka:7.7.1 kafka-storage random-uuid
# Use the SAME value on BOTH nodes.
CLUSTER_ID=REPLACE_WITH_GENERATED_UUID

# ---- EC2 #2 (.env) ----
# NODE_ID=2
# ADVERTISED_HOST=kafka2.general-my.com
# CLUSTER_ID=<same UUID as node 1>
